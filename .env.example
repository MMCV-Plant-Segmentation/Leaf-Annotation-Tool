PORT=5000

# Optional. Absolute path where the backup sidecars (litestream + lsyncd) mirror
# the data volume. Only used with the backup/restore compose profiles:
#   docker compose --profile backup up
# Leave unset to run with no backup (the default for local/dev).
# BACKUP_DIR=/path/to/backup

# Auth vars (added in the auth+admin arc):
# SECRET_KEY=<random 32+ char string>
# ADMIN_PASSWORD=<your admin password>
