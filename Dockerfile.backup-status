# Tiny, dependency-light sidecar: stdlib-only (http.server, urllib), no pip install.
# Only the one module + the trivial package init are copied in — never the rest of
# webapp/ (Flask, Pillow, etc. are not needed here).
FROM python:3.12-alpine
WORKDIR /app
COPY webapp/__init__.py webapp/backup_status.py webapp/
ENV PORT=8098
EXPOSE 8098
ENTRYPOINT ["python3", "-m", "webapp.backup_status"]
