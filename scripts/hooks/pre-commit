#!/usr/bin/env bash
# Rebuild the Solid bundle whenever frontend build-inputs are staged, so the
# committed webapp/static/dist artifact can never go stale relative to its
# source. The bundle is the runtime artifact (`uv run app.py` serves it as-is),
# so a stale bundle ships broken UI even when Vitest is green. See HANDOFF.md.
#
# One-time install per clone:  git config core.hooksPath scripts/hooks
set -euo pipefail

# Only rebuild if the staged changes actually affect the build output.
if ! git diff --cached --name-only \
     | grep -qE '^webapp/frontend/(src/|vite\.config|tsconfig|package\.json)'; then
  exit 0
fi

# Git hooks may run without nvm's PATH — locate npm if it isn't already there.
if ! command -v npm >/dev/null 2>&1; then
  nvm_bin=$(ls -d "$HOME"/.nvm/versions/node/*/bin 2>/dev/null | sort -V | tail -1 || true)
  [ -n "$nvm_bin" ] && export PATH="$nvm_bin:$PATH"
fi
if ! command -v npm >/dev/null 2>&1; then
  echo "[pre-commit] npm not found — cannot rebuild the bundle." >&2
  echo "             Build manually (cd webapp/frontend && npm run build) and re-commit." >&2
  exit 1
fi

echo "[pre-commit] frontend source staged — rebuilding bundle…"
( cd webapp/frontend && npm run build >/dev/null )
git add webapp/static/dist/app.bundle.js webapp/static/dist/app.bundle.css
echo "[pre-commit] webapp/static/dist rebuilt and staged."
